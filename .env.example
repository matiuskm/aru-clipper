# ---- Database ----
# Local dev via docker-compose (Postgres on host port 5433):
DATABASE_URL="postgresql://clipper:clipper@localhost:5433/clipper?schema=public"

# ---- Auth.js (NextAuth v5) ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- Local file storage (Phase 2 stand-in for Cloudflare R2) ----
# Directory where uploaded videos are stored during development.
# Defaults to ./storage if unset.
STORAGE_DIR="storage"

# ---- Cloudflare R2 (used once we swap local storage out) ----
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
CLOUDFLARE_R2_BUCKET_NAME=""
CLOUDFLARE_R2_PUBLIC_DOMAIN=""

# ---- AI providers (Phase 3: transcription & analysis) ----
# Groq Whisper for transcription; Gemini for highlight analysis.
# If a key is empty, that step falls back to a deterministic mock.
GROQ_API_KEY=""
GEMINI_API_KEY=""
# Optional model overrides:
GROQ_WHISPER_MODEL="whisper-large-v3"
GEMINI_MODEL="gemini-2.5-flash"
# Force mock mode for both (offline / free pipeline testing):
AI_MOCK=""
